# ─── Frontend (Vite) ─────────────────────────────────────────────
# Only VITE_-prefixed vars are exposed to the browser bundle. Never put secrets here.

# When "true", the app uses local mock data instead of calling the backend API.
# The backend Worker is NOT wired up yet (scaffold-only phase), so keep this "true".
# Flip to "false" once the Worker API from CLAUDE.md Phase 1 is deployed.
VITE_USE_MOCK=true

# Base URL for the backend API (Cloudflare Worker). Leave blank to use same-origin "/api".
VITE_API_BASE=

# Cloudflare Turnstile site key (public). When set, the intake renders a Turnstile widget
# and the Worker requires a valid token on /api/plan. Leave blank in mock dev. For local
# full-stack testing use Cloudflare's always-pass test key: 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=

# ─── Server-side only (Cloudflare Worker) ────────────────────────
# These live in the Worker, never in the client bundle. Set as Worker secrets:
#   wrangler secret put ANTHROPIC_API_KEY
#   wrangler secret put TURNSTILE_SECRET_KEY
# ANTHROPIC_API_KEY=
# TURNSTILE_SECRET_KEY=
