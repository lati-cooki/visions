# Loaded by `vite build` (production). The deployed app is served by the Worker on the same
# origin, so it calls the real API at /api (VITE_API_BASE blank = same-origin) and the mock
# is off. Local `npm run dev` ignores this file and defaults to mock data.
VITE_USE_MOCK=false
VITE_API_BASE=

# Cloudflare Turnstile site key (public). Gates /api/plan; the Worker verifies the token.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADlQ4vU6OScZ3P8C
