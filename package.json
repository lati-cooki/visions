{
  "name": "visions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visions — Small Business AI Advisor. AI-as-a-service that gives small businesses a personalized AI adoption plan. San Diego is the flagship market.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test worker/test/*.test.js",
    "worker:dev": "wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:schema:local": "wrangler d1 execute visions --local --file=./schema.sql",
    "db:schema:remote": "wrangler d1 execute visions --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute visions --local --file=./migrations/2026-06-15-email-gate.sql",
    "db:migrate:remote": "wrangler d1 execute visions --remote --file=./migrations/2026-06-15-email-gate.sql"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.4",
    "wrangler": "^4.20.0"
  }
}
